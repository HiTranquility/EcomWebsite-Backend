{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Cors": {
    "AllowedOrigins": "https://stag.example.com",
    "AllowCredentials": true
  },

  "HttpLogging": {
    "Enabled": false,
    "IncludeRequestBody": false,
    "IncludeResponseBody": false,
    "RequestBodyLogLimit": 4096,
    "ResponseBodyLogLimit": 4096
  },

  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "",
    "ServiceName": "App-Staging"
  },

  

  "HybridCache": {
    "Enabled": true,
    "ExpirationSeconds": 120,
    "LocalCacheExpirationSeconds": 60,
    "Flags": "None"
  },

  "Database": {
    "AutoMigrate": false,
    "AutoSeed": false,
    "Recreate": false,
    "Strategy": "Migrate",
    "SeedInclude": "",
    "PerBatchTransaction": true
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      },
      "Https": {
        "Url": "https://+:8443",
        "Certificate": {
          "Path": "/https/stagingcert.pfx",
          "Password": ""
        }
      }
    }
  }
}