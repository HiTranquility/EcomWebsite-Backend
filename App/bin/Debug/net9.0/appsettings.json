{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "${Cors__AllowedOrigins}",
    "AllowCredentials": "${Cors__AllowCredentials}"
  },
  "JwtSettings": {
    "SecretKey": "${JwtSettings__SecretKey}",
    "Issuer": "${JwtSettings__Issuer}",
    "Audience": "${JwtSettings__Audience}",
    "TokenExpiryInHours": "${JwtSettings__TokenExpiryInHours}",
    "RefreshTokenExpiryInDays": "${JwtSettings__RefreshTokenExpiryInDays}",
    "RememberMeRefreshTokenExpiryInDays": "${JwtSettings__RememberMeRefreshTokenExpiryInDays}"
  },
  "GoogleAuth": {
    "ClientId": "${GoogleAuth__ClientId}",
    "ClientSecret": "${GoogleAuth__ClientSecret}",
    "RedirectUri": "${GoogleAuth__RedirectUri}"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "${Kestrel__Endpoints__Http__Url}"
      }
    },
    "ConnectionStrings": {},
    "OpenTelemetry": {
      "Enabled": "${OpenTelemetry__Enabled}",
      "OtlpEndpoint": "${OpenTelemetry__OtlpEndpoint}",
      "ServiceName": "${OpenTelemetry__ServiceName}"
    },
    "EmailSettings": {
      "FromEmail": "${EmailSettings__FromEmail}",
      "FromName": "${EmailSettings__FromName}",
      "SmtpHost": "${EmailSettings__SmtpHost}",
      "SmtpPort": "${EmailSettings__SmtpPort}",
      "SmtpUser": "${EmailSettings__SmtpUser}",
      "SmtpPassword": "${EmailSettings__SmtpPassword}",
      "EnableSsl": "${EmailSettings__EnableSsl}"
    },
    "HttpLogging": {
      "Enabled": "${HttpLogging__Enabled}",
      "IncludeRequestBody": "${HttpLogging__IncludeRequestBody}",
      "IncludeResponseBody": "${HttpLogging__IncludeResponseBody}",
      "RequestBodyLogLimit": "${HttpLogging__RequestBodyLogLimit}",
      "ResponseBodyLogLimit": "${HttpLogging__ResponseBodyLogLimit}"
    },
    "CacheSettings": {
      "Enabled": "${CacheSettings__Enabled}",
      "ExpirationSeconds": "${CacheSettings__ExpirationSeconds}",
      "LocalCacheExpirationSeconds": "${CacheSettings__LocalCacheExpirationSeconds}",
      "Flags": "${CacheSettings__Flags}",
      "AppPrefix": "${CacheSettings__AppPrefix}"
    },
    "Redis": {
      "ConnectionString": "${Redis__ConnectionString}",
      "InstanceName": "${Redis__InstanceName}",
      "Observability": {
        "Enabled": "${Redis__Observability__Enabled}",
        "VerboseLogging": "${Redis__Observability__VerboseLogging}"
      }
    },
    "Database": {
      "AutoMigrate": "${Database__AutoMigrate}",
      "AutoSeed": "${Database__AutoSeed}",
      "Recreate": "${Database__Recreate}",
      "Strategy": "${Database__Strategy}",
      "SeedInclude": "${Database__SeedInclude}",
      "PerBatchTransaction": "${Database__PerBatchTransaction}",
      "UsersCount": "${Database__UsersCount}",
      "BatchSizeUsers": "${Database__BatchSizeUsers}",
      "BlogsCount": "${Database__BlogsCount}",
      "BatchSizeBlogs": "${Database__BatchSizeBlogs}"
    },  
    "Session": {
      "IdleTimeoutMinutes": "${Session__IdleTimeoutMinutes}",
      "CookieName": "${Session__CookieName}",
      "RequireConsent": "${Session__RequireConsent}",
      "SameSite": "${Session__SameSite}",
      "SecurePolicy": "${Session__SecurePolicy}",
      "IsEssential": "${Session__IsEssential}"
    },
    "CookiePolicy": {
      "ConsentCookieName": "${CookiePolicy__ConsentCookieName}",
      "ConsentCookieValue": "${CookiePolicy__ConsentCookieValue}",
      "ConsentCookieExpiration": "${CookiePolicy__ConsentCookieExpiration}",
      "ConsentCookieSameSite": "${CookiePolicy__ConsentCookieSameSite}",
      "ConsentCookieSecure": "${CookiePolicy__ConsentCookieSecure}"
    },    
    "RabbitMqSettings": {
      "Enabled": "${RabbitMqSettings__Enabled}",
      "BrokerType": "${RabbitMqSettings__BrokerType}",
      "HostName": "${RabbitMqSettings__HostName}",
      "Port": "${RabbitMqSettings__Port}",
      "UserName": "${RabbitMqSettings__UserName}",
      "Password": "${RabbitMqSettings__Password}",
      "VirtualHost": "${RabbitMqSettings__VirtualHost}",
      "ExchangeType": "${RabbitMqSettings__ExchangeType}",
      "ExchangeName": "${RabbitMqSettings__ExchangeName}"
    }
  }
}