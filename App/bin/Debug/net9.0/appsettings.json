{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Cors": {
    "AllowedOrigins": "${Cors__AllowedOrigins}",
    "AllowCredentials": "${Cors__AllowCredentials}"
  },

  "JwtSettings": {
    "SecretKey": "${JwtSettings__SecretKey}",
    "Issuer": "${JwtSettings__Issuer}",
    "Audience": "${JwtSettings__Audience}",
    "TokenExpiryInHours": "${JwtSettings__TokenExpiryInHours}",
    "RefreshTokenExpiryInDays": "${JwtSettings__RefreshTokenExpiryInDays}",
    "RememberMeRefreshTokenExpiryInDays": "${JwtSettings__RememberMeRefreshTokenExpiryInDays}"
  },

  "Kestrel": {},

  "ConnectionStrings": {
    "MyUserSqlConn": "${ConnectionStrings__MyUserSqlConn}",
    "MyBlogSqlConn": "${ConnectionStrings__MyBlogSqlConn}"
  },

  "OpenTelemetry": {
    "Enabled": "${OpenTelemetry__Enabled}",
    "OtlpEndpoint": "${OpenTelemetry__OtlpEndpoint}",
    "ServiceName": "${OpenTelemetry__ServiceName}"
  },

  "HttpLogging": {
    "Enabled": "${HttpLogging__Enabled}",
    "IncludeRequestBody": "${HttpLogging__IncludeRequestBody}",
    "IncludeResponseBody": "${HttpLogging__IncludeResponseBody}",
    "RequestBodyLogLimit": "${HttpLogging__RequestBodyLogLimit}",
    "ResponseBodyLogLimit": "${HttpLogging__ResponseBodyLogLimit}"
  },

  "HybridCache": {
    "Enabled": "${HybridCache__Enabled}",
    "ExpirationSeconds": "${HybridCache__ExpirationSeconds}",
    "LocalCacheExpirationSeconds": "${HybridCache__LocalCacheExpirationSeconds}",
    "Flags": "${HybridCache__Flags}"
  },

  "Database": {
    "AutoMigrate": "${Database__AutoMigrate}",
    "AutoSeed": "${Database__AutoSeed}",
    "Recreate": "${Database__Recreate}",
    "Strategy": "${Database__Strategy}",
    "SeedInclude": "${Database__SeedInclude}",
    "PerBatchTransaction": "${Database__PerBatchTransaction}",
    "UsersCount": "${Database__UsersCount}",
    "BatchSizeUsers": "${Database__BatchSizeUsers}",
    "BlogsCount": "${Database__BlogsCount}",
    "BatchSizeBlogs": "${Database__BatchSizeBlogs}"
  }
}
