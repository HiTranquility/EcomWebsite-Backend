{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Cors": {
    "AllowedOrigins": "https://stag.example.com",
    "AllowCredentials": true
  },
  
  "HttpLogging": {
    "Enabled": false,
    "IncludeRequestBody": false,
    "IncludeResponseBody": false,
    "RequestBodyLogLimit": 4096,
    "ResponseBodyLogLimit": 4096
  },

  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "",
    "ServiceName": "App-Staging"
  },

  "CacheSettings": {
    "Enabled": true,
    "ExpirationSeconds": 120,
    "LocalCacheExpirationSeconds": 60,
    "Flags": "None",
    "AppPrefix": "ecom"
  },
  "QueueSettings": {
    "Enabled": true,
    "QueueName": "ecom",
    "QueueType": "InMemory"
  },
  "EventBusSettings": {
    "Enabled": true,
    "EventBusType": "InMemory",
    "EventBusName": "ecom"
  },
  "MessageBrokerSettings": {
    "Enabled": true,
    "MessageBrokerType": "InMemory",
    "MessageBrokerName": "ecom"
  },

  "Database": {
    "AutoMigrate": false,
    "AutoSeed": false,
    "Recreate": false,
    "Strategy": "Migrate",
    "SeedInclude": "",
    "PerBatchTransaction": true
  },

  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:8081" },
      "Https": {
        "Url": "https://0.0.0.0:8444",
        "Certificate": {
          "Path": "certs/stag/stagcert.pfx",
          "Password": "stagpass"
        }
      }
    }
  }
}