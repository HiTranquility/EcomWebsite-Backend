{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Cors": {
    "AllowedOrigins": "https://example.com",
    "AllowCredentials": true
  },

  "HttpLogging": {
    "Enabled": false,
    "IncludeRequestBody": false,
    "IncludeResponseBody": false,
    "RequestBodyLogLimit": 4096,
    "ResponseBodyLogLimit": 4096
  },

  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "",
    "ServiceName": "App"
  },

  "CacheSettings": {
    "Enabled": true,
    "ExpirationSeconds": 300,
    "LocalCacheExpirationSeconds": 120,
    "Flags": "None",
    "AppPrefix": "ecom"
  },

    "Database": {
      "AutoSeed": false,
    "Strategy": "Migrate"
  },

  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:8082" },
      "Https": {
        "Url": "https://0.0.0.0:8445",
        "Certificate": {
          "Path": "certs/prod/prodcert.pfx",
          "Password": "prodpass"
        }
      }
    }
  }
}
