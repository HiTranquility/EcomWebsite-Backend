{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "https://your-production-domain.com",
    "AllowCredentials": true
  },
  "JwtSettings": {
    "SecretKey": "ProductionSecretKey_AtLeast64Characters_SuperSecure_ChangeMe_2025!",
    "Issuer": "EcomWebsite",
    "Audience": "EcomWebsiteUsers",
    "TokenExpiryInHours": 24,
    "RefreshTokenExpiryInDays": 7,
    "RememberMeRefreshTokenExpiryInDays": 30
  },
  "GoogleAuth": {
    "ClientId": "your-production-google-client-id",
    "ClientSecret": "your-production-google-client-secret",
    "RedirectUri": "https://your-production-domain.com",
    "ExternalCallbackPath": "/signin-google"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:8080"
      },
      "Https": {
        "Url": "https://localhost:8443",
        "Certificate": {
          "Path": "./certs/prod/prodcert.pfx",
          "Password": "prodpass"
        }
      }
    }
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": "",
    "ServiceName": "EcomWebsite-Prod"
  },
  "EmailSettings": {
    "Provider": "Smtp",
    "FromEmail": "noreply@your-production-domain.com",
    "FromName": "Ecom Website",
    "SendEmailOnRegister": true,
    "VerificationUrl": "https://your-production-domain.com/auth/verify-email",
    "ResetPasswordUrl": "https://your-production-domain.com/auth/reset-password",
    "ForgotPasswordUrl": "https://your-production-domain.com/auth/reset-password",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "User": "your-smtp-user",
      "Password": "your-smtp-password",
      "EnableSsl": true
    }
  },
  "HttpLogging": {
    "Enabled": false,
    "IncludeRequestBody": false,
    "IncludeResponseBody": false,
    "RequestBodyLogLimit": 4096,
    "ResponseBodyLogLimit": 4096
  },
  "CacheSettings": {
    "Enabled": true,
    "ExpirationSeconds": 300,
    "LocalCacheExpirationSeconds": 120,
    "Flags": "None",
    "AppPrefix": "ecom-prod"
  },
  "ConnectionStrings": {
    "MyUserSqlConn": "Server=localhost;Port=3308;Database=ecom_users;User=root;Password=ChangeMe_ProdRoot",
    "MyBlogSqlConn": "Server=localhost;Port=3308;Database=ecom_blogs;User=root;Password=ChangeMe_ProdRoot",
    "MyProductSqlConn": "Server=localhost;Port=3308;Database=ecom_products;User=root;Password=ChangeMe_ProdRoot",
    "MyOrderSqlConn": "Server=localhost;Port=3308;Database=ecom_orders;User=root;Password=ChangeMe_ProdRoot"
  },
  "Redis": {
    "ConnectionString": "localhost:6380",
    "InstanceName": "EcomProd",
    "Observability": {
      "Enabled": false,
      "VerboseLogging": false
    }
  },
  "Database": {
    "SchemaMode": "Migrate",
    "SeedEnabled": false,
    "RecreateOnStart": false,
    "PerBatchTransaction": true,
    "SeedInclude": ""
  },
  "Session": {
    "IdleTimeoutMinutes": 30,
    "CookieName": ".Ecom.Session",
    "RequireConsent": false,
    "SameSite": "Strict",
    "SecurePolicy": "Always",
    "IsEssential": true
  },
  "RabbitMqSettings": {
    "Enabled": true,
    "BrokerType": "RabbitMQ",
    "HostName": "localhost",
    "Port": 5673,
    "UserName": "app",
    "Password": "ChangeMe_ProdRabbit",
    "VirtualHost": "/",
    "ExchangeType": "direct",
    "ExchangeName": "email.exchange"
  },
  "KafkaSettings": {
    "Enabled": false
  }
}